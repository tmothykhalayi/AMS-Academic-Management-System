### Base URL
@baseUrl = http://localhost:8000

### ========================================
### USER ENDPOINTS
### ========================================

### Create User
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "John Doe",
  "email": "john.doe@example.com",
  "password": "password123"
}

### Get All Users
GET {{baseUrl}}/users

### Get User by ID
GET {{baseUrl}}/users/1

### Update User
PATCH {{baseUrl}}/users/1
Content-Type: application/json

{
  "name": "John Doe Updated",
  "email": "john.updated@example.com"
}

### ========================================
### SURVEY ENDPOINTS
### ========================================

### Create Survey
POST {{baseUrl}}/surveys
Content-Type: application/json

{
  "title": "Customer Satisfaction Survey",
  "description": "Please help us improve our services",
  "userId": 1
}

### Get All Surveys
GET {{baseUrl}}/surveys

### Get Survey by ID
GET {{baseUrl}}/surveys/1

### Update Survey
PATCH {{baseUrl}}/surveys/1
Content-Type: application/json

{
  "title": "Updated Customer Satisfaction Survey",
  "description": "Updated description"
}

### ========================================
### QUESTION ENDPOINTS
### ========================================

### Create Question - Text Type
POST {{baseUrl}}/questions
Content-Type: application/json

{
  "text": "What is your name?",
  "type": "text",
  "surveyId": 1
}

### Create Question - Radio Type
POST {{baseUrl}}/questions
Content-Type: application/json

{
  "text": "How satisfied are you with our service?",
  "type": "radio",
  "surveyId": 1
}

### Create Question - Checkbox Type
POST {{baseUrl}}/questions
Content-Type: application/json

{
  "text": "Which features do you use?",
  "type": "checkbox",
  "surveyId": 1
}

### Create Question - Rating Type
POST {{baseUrl}}/questions
Content-Type: application/json

{
  "text": "Rate our customer support",
  "type": "rating",
  "surveyId": 1
}

### Get All Questions
GET {{baseUrl}}/questions

### Get Question by ID
GET {{baseUrl}}/questions/1

### Update Question
PATCH {{baseUrl}}/questions/1
Content-Type: application/json

{
  "text": "What is your full name?",
  "type": "text"
}

### ========================================
### RESPONSE ENDPOINTS
### ========================================

### Create Response - Text Answer
POST {{baseUrl}}/responses
Content-Type: application/json

{
  "answer": "Jane Smith",
  "surveyId": 1,
  "questionId": 1,
  "userId": 1
}

### Create Response - Radio Answer
POST {{baseUrl}}/responses
Content-Type: application/json

{
  "answer": "Very Satisfied",
  "surveyId": 1,
  "questionId": 2,
  "userId": 1
}

### Create Response - Checkbox Answer
POST {{baseUrl}}/responses
Content-Type: application/json

{
  "answer": ["Feature A", "Feature B", "Feature C"],
  "surveyId": 1,
  "questionId": 3,
  "userId": 1
}

### Create Response - Rating Answer
POST {{baseUrl}}/responses
Content-Type: application/json

{
  "answer": 5,
  "surveyId": 1,
  "questionId": 4,
  "userId": 1
}

### Get All Responses
GET {{baseUrl}}/responses

### Get Response by ID
GET {{baseUrl}}/responses/1

### Update Response
PATCH {{baseUrl}}/responses/1
Content-Type: application/json

{
  "answer": "Updated Answer"
}

### ========================================
### WORKFLOW EXAMPLES
### ========================================

### Example 1: Create User
POST {{baseUrl}}/users
Content-Type: application/json

{
  "name": "Alice Johnson",
  "email": "alice@example.com",
  "password": "secure123"
}

### Example 2: Create Survey for User 2
POST {{baseUrl}}/surveys
Content-Type: application/json

{
  "title": "Product Feedback Survey",
  "description": "Help us understand your needs",
  "userId": 2
}

### Example 3: Add Questions to Survey 2
POST {{baseUrl}}/questions
Content-Type: application/json

{
  "text": "What product features would you like to see?",
  "type": "text",
  "surveyId": 2
}

### Example 4: Submit Response
POST {{baseUrl}}/responses
Content-Type: application/json

{
  "answer": "Dark mode and mobile app",
  "surveyId": 2,
  "questionId": 5,
  "userId": 2
}
